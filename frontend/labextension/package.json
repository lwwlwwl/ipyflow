{
  "name": "jupyterlab-ipyflow",
  "description": "JupyterLab extension for ipyflow user interface",
  "type": "module",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension"
  ],
  "homepage": "https://github.com/ipyflow/ipyflow",
  "bugs": {
    "url": "https://github.com/ipyflow/ipyflow/issues"
  },
  "license": "BSD-3-Clause",
  "author": "Stephen Macke",
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}",
    "style/**/*.{css,eot,gif,html,jpg,json,png,svg,woff2,ttf}"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "repository": {
    "type": "git",
    "url": "https://github.com/ipyflow/ipyflow.git"
  },
  "scripts": {
    "build:classes": "mv style/index.css style/index.module.css && tcm style --outDir style --camelCase && cp style/index.module.css style/index.css",
    "build:lib": "tsc",
    "build:dev": "npm run build:classes && npm run build:lib && npm run build:labextension:dev",
    "build": "npm run build:classes && npm run build:lib && npm run build:labextension",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "clean": "npm run clean:lib",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "prettier": "prettier --check 'src/**/*.ts'",
    "prettier:fix": "prettier --write 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "install:extension": "jupyter labextension develop --overwrite .",
    "prepare": "npm run clean && npm run build",
    "watch": "run-p watch:src watch:labextension",
    "watch:src": "tsc -w",
    "watch:labextension": "jupyter labextension watch ."
  },
  "dependencies": {
    "@jupyterlab/application": "^4.5.7",
    "@jupyterlab/coreutils": "^6.5.7",
    "@jupyterlab/notebook": "^4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jupyterlab/builder": "^4.5.7",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "npm-run-all2": "^9.0.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typed-css-modules": "^0.9.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "overridesComment": "Pin webpack < 5.104: 5.104 changed ProvideSharedModule.identifier() to a '|' separator that @jupyterlab/builder's bundled license-webpack-plugin (2.3.21) cannot parse (it splits on '='), crashing the labextension build.",
  "overrides": {
    "webpack": "5.103.0"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "../../core/ipyflow/resources/labextension/"
  },
  "version": "0.0.227"
}